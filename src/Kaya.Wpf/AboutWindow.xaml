<Window x:Class="Kaya.Wpf.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Save Button" SizeToContent="Height" Width="350"
        WindowStartupLocation="CenterOwner"
        Icon="app.ico"
        ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Save Button" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10" />
            <TextBlock Text="Version 0.2.2" HorizontalAlignment="Center"
                       Margin="0,0,0,15" />
            <TextBlock Text="A bookmarking and notes app."
                       HorizontalAlignment="Center" Margin="0,0,0,15" />
            <TextBlock Text="&#169; 2026 Steven Deobald"
                       HorizontalAlignment="Center" Foreground="Gray" Margin="0,0,0,20" />
            <Button Content="OK" Click="OnOK" HorizontalAlignment="Center"
                    Padding="30,6" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="Kaya.Wpf.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview" Height="600" Width="800"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Icon="app.ico"
        KeyDown="OnWindowKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar with sidebar toggle -->
        <Grid Grid.Row="0" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="WindowTitleText" Grid.Column="0" FontSize="16"
                       FontWeight="SemiBold" VerticalAlignment="Center" />
            <ToggleButton Grid.Column="1" x:Name="SidebarToggle" Content="Sidebar"
                          IsChecked="True" Click="OnSidebarToggle" Padding="8,4" />
        </Grid>

        <!-- Main Content Area: Split View -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <!-- Content: 61.8% (golden ratio) -->
                <ColumnDefinition Width="618*" />
                <!-- Sidebar: 38.2% -->
                <ColumnDefinition x:Name="SidebarColumn" Width="382*" />
            </Grid.ColumnDefinitions>

            <!-- Content Area -->
            <Border Grid.Column="0" Margin="0,0,5,0">
                <Grid>
                    <!-- Bookmark Content -->
                    <StackPanel x:Name="BookmarkPanel" Visibility="Collapsed"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#128279;" FontSize="64" HorizontalAlignment="Center"
                                   Margin="0,0,0,10" />
                        <TextBlock x:Name="BookmarkUrlText" FontSize="14"
                                   TextWrapping="Wrap" HorizontalAlignment="Center"
                                   Margin="0,0,0,10" />
                        <Button x:Name="BookmarkVisitButton" Content="Visit Website"
                                Click="OnVisitBookmark" HorizontalAlignment="Center"
                                Padding="16,6" Foreground="White" Background="#FF0078D4">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <!-- Note Content -->
                    <ScrollViewer x:Name="NotePanel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Padding="10">
                        <TextBlock x:Name="NoteContentText" TextWrapping="Wrap" FontSize="14" />
                    </ScrollViewer>

                    <!-- Image Content -->
                    <Border x:Name="ImagePanel" Visibility="Collapsed">
                        <Image x:Name="ImagePreview" Stretch="Uniform" />
                    </Border>

                    <!-- PDF Content -->
                    <Grid x:Name="PdfPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0">
                            <Image x:Name="PdfPageImage" Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Button x:Name="PdfPrevButton" Content="Previous"
                                    Click="OnPdfPrev" Padding="10,4" Margin="0,0,5,0" />
                            <TextBlock x:Name="PdfPageLabel" VerticalAlignment="Center"
                                       Margin="10,0" />
                            <Button x:Name="PdfNextButton" Content="Next"
                                    Click="OnPdfNext" Padding="10,4" Margin="5,0,0,0" />
                            <Button x:Name="PdfOpenButton" Content="Open Externally"
                                    Click="OnOpenExternally" Padding="10,4" Margin="15,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Generic File Content -->
                    <StackPanel x:Name="FilePanel" Visibility="Collapsed"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="FileTypeIcon" Text="&#128196;" FontSize="64"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <TextBlock x:Name="FileTypeLabel" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <Button Content="Open Externally" Click="OnOpenExternally"
                                HorizontalAlignment="Center" Padding="16,6" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Column="1" x:Name="SidebarPanel" Margin="5,0,0,0" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Tags -->
                        <TextBlock Text="Tags" FontWeight="SemiBold" Margin="0,0,0,5" />
                        <Border BorderThickness="1" CornerRadius="4" Padding="4,2"
                                MinHeight="32" Margin="0,0,0,15">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto" MaxHeight="80">
                                <WrapPanel x:Name="TagsPanel">
                                    <TextBox x:Name="TagsEntry" BorderThickness="0" MinWidth="80"
                                             Background="Transparent" VerticalAlignment="Center"
                                             Margin="2" PreviewKeyDown="OnTagsPreviewKeyDown" />
                                </WrapPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Note -->
                        <TextBlock Text="Note" FontWeight="SemiBold" Margin="0,0,0,5" />
                        <TextBox x:Name="SidebarNoteText" AcceptsReturn="True"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 MinHeight="100" Margin="0,0,0,15" />

                        <!-- Share -->
                        <TextBlock x:Name="ShareSectionLabel" Text="Share"
                                   FontWeight="SemiBold" Margin="0,0,0,5" Foreground="Gray" />
                        <Button x:Name="ShareButton" Content="Share" Click="OnShare"
                                IsEnabled="False" Padding="16,6" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Toast -->
        <Border Grid.Row="2" x:Name="ToastBorder" Background="#FF4CAF50"
                Padding="10,6" Visibility="Collapsed">
            <TextBlock x:Name="ToastText" Foreground="White"
                       HorizontalAlignment="Center" FontSize="13" />
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="10">
            <Button Content="Cancel" Click="OnCancel" Padding="20,6" Margin="0,0,10,0" />
            <Button x:Name="SaveButton" Content="Save" Click="OnSave"
                    Padding="20,6" IsDefault="True"
                    Foreground="White" Background="#FF0078D4" />
        </StackPanel>
    </Grid>
</Window>

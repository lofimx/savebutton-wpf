<Window x:Class="Kaya.Wpf.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences" SizeToContent="Height" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MaxHeight="720"
        Icon="app.ico">
    <TabControl Margin="10">
        <!-- Sync Tab -->
        <TabItem Header="Sync">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- SIGNED OUT state -->
                <StackPanel Grid.Row="0" x:Name="SignedOutPanel" Visibility="Collapsed">
                    <TextBlock Text="Sign In" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                    <Button x:Name="GoogleButton" Click="OnSignInGoogle"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,10" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="GoogleIcon" Width="20" Height="20" Margin="0,0,10,0" />
                            <TextBlock Text="Sign In with Google" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="MicrosoftButton" Click="OnSignInMicrosoft"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,10" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="MicrosoftIcon" Width="20" Height="20" Margin="0,0,10,0" />
                            <TextBlock Text="Sign In with Microsoft" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="AppleButton" IsEnabled="False"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,10" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="AppleIcon" Width="20" Height="20" Margin="0,0,10,0" />
                            <TextBlock Text="Sign In with Apple (Coming soon)" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Separator Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="or" Foreground="Gray"
                                   Margin="8,0,8,0" VerticalAlignment="Center" />
                        <Separator Grid.Column="2" VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="Email" Margin="0,0,0,4" />
                    <TextBox x:Name="EmailEntry" Margin="0,0,0,10" Padding="6,4" />

                    <TextBlock Text="Password" Margin="0,0,0,4" />
                    <PasswordBox x:Name="PasswordEntry" Margin="0,0,0,10" Padding="6,4" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="SignInButton" Content="Sign In" Click="OnSignInEmail"
                                Padding="20,6" Margin="0,0,10,0"
                                Foreground="White" Background="#FF0078D4" />
                    </StackPanel>

                    <Button x:Name="SignUpButton" Click="OnSignUp"
                            HorizontalAlignment="Left"
                            Padding="4,2" Margin="0,0,0,12"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FF0078D4" Cursor="Hand">
                        <TextBlock Text="Don't have an account? Sign Up"
                                   TextDecorations="Underline" />
                    </Button>

                    <TextBlock x:Name="SignInStatusText" TextWrapping="Wrap"
                               Foreground="#FFD32F2F" Margin="0,0,0,10" />
                </StackPanel>

                <!-- SIGNED IN state -->
                <StackPanel Grid.Row="0" x:Name="SignedInPanel" Visibility="Collapsed">
                    <TextBlock Text="Connected" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                    <Border BorderBrush="#FFE0E0E0" BorderThickness="1"
                            CornerRadius="4" Padding="12" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="ConnectedProviderIcon" Width="32" Height="32"
                                   Margin="0,0,12,0" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="ConnectedProviderText" FontWeight="SemiBold"
                                           Text="Signed in with" />
                                <TextBlock x:Name="ConnectedEmailText" Foreground="Gray"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button x:Name="SignOutButton" Content="Sign Out" Click="OnSignOut"
                            HorizontalAlignment="Left" Padding="20,6" Margin="0,0,0,16"
                            Foreground="White" Background="#FFD32F2F" />

                    <TextBlock Text="Actions" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
                    <TextBlock x:Name="SyncStatusText" TextWrapping="Wrap" Margin="0,0,0,10"
                               Foreground="Gray" />
                    <Button x:Name="ForceSyncButton" Content="Force Sync" Click="OnForceSync"
                            HorizontalAlignment="Left" Padding="20,6" Margin="0,0,0,16" />
                </StackPanel>

                <!-- SERVER section (always visible) -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="Save Button Server" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
                    <TextBlock Text="Server URL" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBox x:Name="ServerUrlEntry" Width="310" Padding="6,4"
                                 TextChanged="OnServerUrlChanged" />
                        <Button x:Name="SaveServerUrlButton" Content="Save" Click="OnSaveServerUrl"
                                Padding="16,4" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock x:Name="PrivateUrlWarning" TextWrapping="Wrap"
                               Foreground="#FFB8860B" FontSize="12"
                               Margin="0,6,0,0" Visibility="Collapsed"
                               Text="Email/password sign-in works with a LAN IP, but OAuth (Google, Microsoft) will not reach your browser. Use an ngrok tunnel for OAuth testing." />
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Browser Tab -->
        <TabItem Header="Browser">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Browser Extension" FontWeight="Bold"
                           FontSize="16" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,15"
                           Text="The Save Button browser extension connects to this app over HTTP on localhost. Set the port number below to match your browser extension configuration." />

                <TextBlock Grid.Row="2" Text="Native Host Port" Margin="0,0,0,5" />
                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <TextBox x:Name="NativeHostPortEntry" Width="100" Margin="0,0,10,0" />
                    <Button Content="Save" Click="OnSaveNativeHostPort" Padding="20,6"
                            Foreground="White" Background="#FF0078D4" />
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>

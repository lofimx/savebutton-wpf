<Window x:Class="Kaya.Wpf.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences" SizeToContent="Height" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MaxHeight="700"
        Icon="app.ico">
    <TabControl Margin="10">
        <!-- Sync Tab -->
        <TabItem Header="Sync">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Kaya Server Section -->
                <TextBlock Grid.Row="0" Text="Kaya Server" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" Text="Server URL" Margin="0,0,0,5" />
                <TextBox Grid.Row="2" x:Name="ServerUrlEntry" Margin="0,0,0,15" />

                <!-- Account Section -->
                <TextBlock Grid.Row="3" Text="Account" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                <TextBlock Grid.Row="4" Text="Email" Margin="0,0,0,5" />
                <TextBox Grid.Row="5" x:Name="EmailEntry" Margin="0,0,0,10" />

                <TextBlock Grid.Row="6" Text="Password" Margin="0,0,0,5" />
                <PasswordBox Grid.Row="7" x:Name="PasswordEntry" Margin="0,0,0,10" />

                <!-- Save / Clear Buttons -->
                <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="SaveCredentialsButton" Content="Save" Click="OnSaveCredentials"
                            Padding="20,6" Margin="0,0,10,0"
                            Foreground="White" Background="#FF0078D4">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="ClearCredentialsButton" Content="Clear" Click="OnClearCredentials"
                            Padding="20,6"
                            Foreground="White" Background="#FFD32F2F">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Status Section -->
                <StackPanel Grid.Row="9" Margin="0,5,0,0">
                    <TextBlock Text="Status" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
                    <TextBlock x:Name="SyncStatusText" TextWrapping="Wrap" Margin="0,0,0,10"
                               Foreground="Gray" />
                    <Button x:Name="ForceSyncButton" Content="Force Sync" Click="OnForceSync"
                            HorizontalAlignment="Left" Padding="20,6" />
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Browser Tab -->
        <TabItem Header="Browser">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Browser Extension" FontWeight="Bold"
                           FontSize="16" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,15"
                           Text="The Save Button browser extension connects to this app over HTTP on localhost. Set the port number below to match your browser extension configuration." />

                <TextBlock Grid.Row="2" Text="Native Host Port" Margin="0,0,0,5" />
                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <TextBox x:Name="NativeHostPortEntry" Width="100" Margin="0,0,10,0" />
                    <Button Content="Save" Click="OnSaveNativeHostPort" Padding="20,6"
                            Foreground="White" Background="#FF0078D4">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
